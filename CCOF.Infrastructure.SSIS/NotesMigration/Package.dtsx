                      externalMetadataColumnId="Package\Data Flow Task\Dataverse Destination.Inputs[Input].ExternalColumns[owneridtype]"
                      lineageId="Package\Data Flow Task\Derived Column.Outputs[Derived Column Output].Columns[owneridtype]" />
                    <inputColumn
                      refId="Package\Data Flow Task\Dataverse Destination.Inputs[Input].Columns[crc7e_ccof_category]"
                      cachedDataType="wstr"
                      cachedLength="100"
                      cachedName="crc7e_ccof_category"
                      externalMetadataColumnId="Package\Data Flow Task\Dataverse Destination.Inputs[Input].ExternalColumns[ccof_category]"
                      lineageId="Package\Data Flow Task\Dataverse Source.Outputs[Primary Output].Columns[crc7e_ccof_category]" />
                    <inputColumn
                      refId="Package\Data Flow Task\Dataverse Destination.Inputs[Input].Columns[crc7e_orgid]"
                      cachedDataType="wstr"
                      cachedLength="100"
                      cachedName="crc7e_orgid"
                      externalMetadataColumnId="Package\Data Flow Task\Dataverse Destination.Inputs[Input].ExternalColumns[regardingobjectid]"
                      lineageId="Package\Data Flow Task\Dataverse Source.Outputs[Primary Output].Columns[crc7e_orgid]" />
                    <inputColumn
                      refId="Package\Data Flow Task\Dataverse Destination.Inputs[Input].Columns[regardingobjecttypecode]"
                      cachedDataType="i4"
                      cachedName="regardingobjecttypecode"
                      externalMetadataColumnId="Package\Data Flow Task\Dataverse Destination.Inputs[Input].ExternalColumns[regardingobjecttypecode]"
                      lineageId="Package\Data Flow Task\Derived Column.Outputs[Derived Column Output].Columns[regardingobjecttypecode]" />
                    <inputColumn
                      refId="Package\Data Flow Task\Dataverse Destination.Inputs[Input].Columns[crc7e_event_dt]"
