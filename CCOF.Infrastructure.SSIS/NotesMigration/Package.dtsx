  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Data Flow Task"
      DTS:CreationName="Microsoft.Pipeline"
      DTS:Description="Data Flow Task"
      DTS:DTSID="{CB997963-24D2-469C-A47C-C45F3D0A18F3}"
      DTS:ExecutableType="Microsoft.Pipeline"
      DTS:LocaleID="-1"
      DTS:ObjectName="Data Flow Task">
      <DTS:Variables />
      <DTS:ObjectData>
        <pipeline
          version="1">
          <components>
            <component
              refId="Package\Data Flow Task\Dataverse Destination"
              componentClassID="Microsoft.ManagedComponentHost"
              contactInfo="KingswaySoft Inc.; http://www.kingswaysoft.com; support@kingswaysoft.com; Copyright (c) 2011-2025 KingswaySoft Inc."
              description="Populate data into Dataverse, PowerApps, Microsoft Dynamics 365 CE."
              name="Dataverse Destination"
              usesDispositions="true"
              version="4">
              <properties>
                <property
                  dataType="System.String"
                  description="Destination entity to write data."
                  expressionType="Notify"
                  name="DestinationEntity">ccof_notes</property>
                <property
                  dataType="System.Int32"
                  description="Specifies how data is written to CDS/Dynamics CRM server."
                  name="ActionType"
                  typeConverter="KingswaySoft.IntegrationToolkit.DynamicsCrm.DestinationActionType">1</property>
                <property
                  dataType="System.Boolean"
                  description="Specifies whether the values of CDS/CRM lookup fields should be removed if the reference records cannot be found. "
                  expressionType="Notify"
                  name="RemoveUnresolvableReferences">false</property>
                <property
                  dataType="System.Boolean"
                  description="Specifies whether duplicate detection should be enabled when creating or updating CDS/CRM records. Duplicate records are determined by the duplicate detection rules and settings defined in CDS or Microsoft Dynamics CRM server."
                  expressionType="Notify"
                  name="EnableSystemDuplicateDetection">false</property>
                <property
                  dataType="System.Int32"
                  description="Specify the matching criteria to be used when performing an update or upsert. "
                  expressionType="Notify"
                  name="RecordMatchingCriteria"
                  typeConverter="KingswaySoft.IntegrationToolkit.Common.DescriptiveEnumTypeConverter`1[[KingswaySoft.IntegrationToolkit.DynamicsCrm.RecordMatchingCriteria">0</property>
                <property
                  dataType="System.String"
                  description="Specify the key fields to be used to determine the matching records that exist in CDS/CRM for either Upsert/Update action or source duplicate optimization."
                  expressionType="Notify"
                  name="RecordMatchingKeyFields"></property>
                <property
                  dataType="System.Boolean"
                  description="Specifies whether to ignore those NULL-valued fields."
                  expressionType="Notify"
                  name="IgnoreNullValuedFields">false</property>
                <property
                  dataType="System.Boolean"
                  description="Specifies whether to ignore those fields that have no value changes in the target system. "
                  expressionType="Notify"
                  name="IgnoreUnchangedFields">false</property>
                <property
                  dataType="System.Boolean"
                  description="Specify whether to remove those invalid characters before writing to CDS/CRM."
                  expressionType="Notify"
                  name="RemoveInvalidCharacters">false</property>
                <property
                  dataType="System.String"
                  description="Specify the flag field(s) that are used to track the source of changes. The field(s) will not posted to CDS/CRM server unless there are changes to other fields if specified. &quot;Ignore Unchange Fields&quot; option is required in order for the specified flag field(s) to work. "
                  expressionType="Notify"
                  name="ChangeFlagFields"></property>
                <property
                  dataType="System.Int32"
                  description="Specifies what action will be taken when multiple matches are found with Upsert action."
                  expressionType="Notify"
                  name="HandlingOfMultipleMatches"
                  typeConverter="KingswaySoft.IntegrationToolkit.Common.DescriptiveEnumTypeConverter`1[[KingswaySoft.IntegrationToolkit.DynamicsCrm.HandlingOfMultipleMatches">0</property>
                <property
                  dataType="System.Int32"
                  description="Specify whether to use optimizations when there are duplicate records form the source system."
                  expressionType="Notify"
                  name="OptimizationOnSourceDuplicates"
                  typeConverter="KingswaySoft.IntegrationToolkit.Common.DescriptiveEnumTypeConverter`1[[KingswaySoft.IntegrationToolkit.DynamicsCrm.OptimizationOnSourceDuplicates">0</property>
                <property
                  dataType="System.String"
                  description="Workflow or action to be executed."
                  expressionType="Notify"
                  name="WorkflowAction"></property>
                <property
                  dataType="System.Int32"
                  description="Specifies the number of records to be sent to CDS/Dynamics CRM server in each service call."
                  expressionType="Notify"
                  name="BatchSize">75</property>
                <property
                  dataType="System.Int32"
                  description="Specify the total number or concurrent threads to write to CDS/CRM server simultaneously. "
                  expressionType="Notify"
                  name="ConcurrentWritingThreadsInTotal">10</property>
                <property
                  dataType="System.Boolean"
                  description="Specifies whether datetime values should be sent to CDS/CRM server in UTC format."
                  expressionType="Notify"
                  name="SendDateTimeInUtcFormat">true</property>
                <property
                  dataType="System.String"
                  description="Specify whether to bypass synchronous logic, asynchronous logic or, both during writing. "
                  expressionType="Notify"
                  name="BypassBusinessLogicExecution"></property>
                <property
                  dataType="System.String"
                  description="Specify the registered plug-in steps that should be bypassed during runtime instead of all synchronous and asynchronous custom logic. "
                  expressionType="Notify"
                  name="BypassBusinessLogicExecutionStepIds"></property>
                <property
                  dataType="System.String"
                  name="UserComponentTypeName">KingswaySoft.IntegrationToolkit.DynamicsCrm.DataverseDestinationComponent</property>
                <property
                  dataType="System.Boolean"
                  description="Specify whether to use those homogeneous batch operation messages (such as CreateMultiple, UpdateMultiple, DeleteMultiple, etc.) for more efficient batch writing (if supported). "
                  expressionType="Notify"
                  name="UseHomogeneousBatchOperationMessages">false</property>
                <property
                  dataType="System.Boolean"
                  description="Specify whethere to tentatively disable entity change tracking (auditing)"
                  expressionType="Notify"
                  name="TentativelyDisableEntityAuditing">true</property>
                <property
                  dataType="System.Boolean"
                  description="Specify whether to leverage the platform feature to suppress callback registration expander jobs during the data load."
                  expressionType="Notify"
                  name="SuppressCallbackRegistrationExpanderJob">true</property>
                <property
                  dataType="System.Boolean"
                  description="Specify whether to tentatively disable relevant plugins"
                  expressionType="Notify"
                  name="TentativelyDisableRelevantPlugins">true</property>
                <property
                  dataType="System.Boolean"
                  description="Specify whether to tentatively disable relevant workflows"
                  expressionType="Notify"
                  name="TentativelyDisableRelevantWorkflows">true</property>
              </properties>
              <connections>
                <connection
                  refId="Package\Data Flow Task\Dataverse Destination.Connections[DynamicsCRM]"
                  connectionManagerID="{BD7D8DD3-5A61-4638-9BBF-15DA8095EF96}:external"
                  connectionManagerRefId="Project.ConnectionManagers[UAT_Final]"
                  description="Dynamics CRM Connection Manager"
                  name="DynamicsCRM" />
              </connections>
              <inputs>
                <input
                  refId="Package\Data Flow Task\Dataverse Destination.Inputs[Input]"
                  errorOrTruncationOperation="Insert"
                  errorRowDisposition="RedirectRow"
                  hasSideEffects="true"
                  name="Input">
                  <inputColumns>
                    <inputColumn
                      refId="Package\Data Flow Task\Dataverse Destination.Inputs[Input].Columns[crc7e_event_name_txt]"
                      cachedDataType="wstr"
                      cachedLength="100"
                      cachedName="crc7e_event_name_txt"
                      externalMetadataColumnId="Package\Data Flow Task\Dataverse Destination.Inputs[Input].ExternalColumns[subject]"
                      lineageId="Package\Data Flow Task\Dataverse Source.Outputs[Primary Output].Columns[crc7e_event_name_txt]" />
                    <inputColumn
